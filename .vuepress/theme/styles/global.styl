// 全局样式优化
// 字体、颜色、基础组件美化

// 字体系统 - 使用更现代的字体组合
$body-font-family = -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans SC', 'Microsoft YaHei', sans-serif
$heading-font-family = -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans SC', 'Microsoft YaHei', sans-serif
$code-font-family = 'Fira Code', 'Consolas', 'Monaco', 'Courier New', monospace

// 颜色系统
$primary-color = #3b82f6
$primary-light = #60a5fa
$primary-dark = #2563eb

$text-primary = #0f172a
$text-secondary = #475569
$text-muted = #94a3b8

$bg-primary = #ffffff
$bg-secondary = #f8fafc
$bg-tertiary = #f1f5f9

$border-color = #e2e8f0
$border-color-hover = #cbd5e1

// 全局样式
:root
  font-family $body-font-family
  -webkit-font-smoothing antialiased
  -moz-osx-font-smoothing grayscale

html
  font-size 16px
  scroll-behavior smooth

body
  font-family $body-font-family
  color $text-primary
  line-height 1.75
  background-color $bg-primary

// 滚动条美化
::-webkit-scrollbar
  width 8px
  height 8px

::-webkit-scrollbar-track
  background $bg-secondary
  border-radius 4px

::-webkit-scrollbar-thumb
  background #cbd5e1
  border-radius 4px
  transition background 0.2s ease

::-webkit-scrollbar-thumb:hover
  background #94a3b8

// 选择文本样式
::selection
  background rgba(59, 130, 246, 0.2)
  color $text-primary

// 链接通用样式
a
  color $primary-color
  text-decoration none
  transition color 0.2s ease, border-color 0.2s ease

  &:hover
    color $primary-dark
    text-decoration underline
    text-decoration-thickness 1px
    text-underline-offset 2px

  &:active
    color $primary-dark

// 标题样式
h1, h2, h3, h4, h5, h6
  font-family $heading-font-family
  font-weight 600
  line-height 1.4
  color $text-primary
  margin-top 2rem
  margin-bottom 1rem

  &:first-child
    margin-top 0

h1
  font-size 2.25rem
  letter-spacing -0.02em

h2
  font-size 1.875rem
  letter-spacing -0.01em

h3
  font-size 1.5rem

h4
  font-size 1.25rem

h5
  font-size 1.125rem

h6
  font-size 1rem
  font-weight 500
  color $text-secondary

// 段落样式
p
  margin-bottom 1rem
  line-height 1.75

// 列表样式
ul, ol
  margin 1rem 0
  padding-left 1.5rem

li
  margin-bottom 0.5rem
  line-height 1.6

// 引用样式
blockquote
  margin 1.5rem 0
  padding 1rem 1.5rem
  background-color $bg-secondary
  border-left 4px solid $primary-color
  border-radius 0 8px 8px 0

  p
    margin-bottom 0
    color $text-secondary

    &:last-child
      margin-bottom 0

// 表格样式
table
  width 100%
  margin 1.5rem 0
  border-collapse collapse
  font-size 0.95rem

th, td
  padding 0.75rem 1rem
  text-align left
  border-bottom 1px solid $border-color

th
  font-weight 600
  color $text-primary
  background-color $bg-secondary

  &:first-child
    border-top-left-radius 8px

  &:last-child
    border-top-right-radius 8px

tr:last-child td
  border-bottom none

tr:hover td
  background-color $bg-secondary

// 分隔线样式
hr
  border none
  height 1px
  background linear-gradient(90deg, transparent, $border-color, transparent)
  margin 2rem 0

// 代码块内联样式
code
  font-family $code-font-family
  font-size 0.875em
  padding 0.2rem 0.4rem
  background-color rgba(59, 130, 246, 0.1)
  color $primary-dark
  border-radius 4px
  word-break break-word

pre
  margin 1.5rem 0
  background-color #1e293b
  border-radius 8px
  overflow-x auto
  box-shadow 0 4px 6px rgba(0, 0, 0, 0.1)

  code
    padding 1.25rem
    font-size 0.875rem
    line-height 1.6
    background-color transparent
    color #e2e8f0
    border-radius 0

// 强调样式
strong, b
  font-weight 600
  color $text-primary

em, i
  font-style italic

// 删除线
del, s
  color $text-muted
  text-decoration line-through

// 标签样式
kbd
  display inline-block
  padding 0.25rem 0.5rem
  font-size 0.875rem
  font-family $code-font-family
  background-color $bg-tertiary
  border 1px solid $border-color
  border-bottom 2px solid $border-color
  border-radius 4px
  box-shadow 0 1px 2px rgba(0, 0, 0, 0.05)

// 图片样式
img
  max-width 100%
  height auto
  border-radius 8px
  box-shadow 0 4px 6px rgba(0, 0, 0, 0.1)

// 深色模式支持
@media (prefers-color-scheme: dark)
  body
    background-color #0f172a
    color #f1f5f9

  h1, h2, h3, h4, h5, h6
    color #f1f5f9

  h6
    color #94a3b8

  blockquote
    background-color rgba(148, 163, 184, 0.1)
    border-left-color $primary-light

    p
      color #cbd5e1

  table
    th
      background-color rgba(148, 163, 184, 0.1)
      color #f1f5f9

    tr:hover td
      background-color rgba(148, 163, 184, 0.05)

  code
    background-color rgba(96, 165, 250, 0.15)
    color $primary-light

  ::-webkit-scrollbar-track
    background #1e293b

  ::-webkit-scrollbar-thumb
    background #475569

  ::-webkit-scrollbar-thumb:hover
    background #64748b

// 响应式优化
@media (max-width: $MQNarrow)
  h1
    font-size 2rem

  h2
    font-size 1.5rem

  h3
    font-size 1.25rem

@media (max-width: $MQMobile)
  h1
    font-size 1.75rem

  h2
    font-size 1.375rem

  h3
    font-size 1.125rem
