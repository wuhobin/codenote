// 目录（TOC）样式优化
// 右侧文章目录美化

.toc-sidebar-links
  list-style none
  padding 0
  margin 0

  // 目录链接
  a.toc-sidebar-link
    display block
    padding 0.4rem 0.75rem
    margin-bottom 0.25rem
    font-size 0.85rem
    line-height 1.5
    color $text-secondary
    text-decoration none
    border-left 2px solid transparent
    border-radius 0 6px 6px 0
    transition all 0.2s ease
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

    &:hover
      color $text-primary
      background-color rgba(59, 130, 246, 0.05)
      border-left-color rgba(59, 130, 246, 0.3)

    &.active
      color $primary-color
      background-color rgba(59, 130, 246, 0.1)
      border-left-color $primary-color
      font-weight 500

      &::before
        content ''
        position absolute
        left 0.5rem
        width 4px
        height 4px
        background $primary-color
        border-radius 50%

  // 子目录
  .toc-sidebar-sub-headers
    padding-left 0.75rem
    margin-top 0.25rem

    a.toc-sidebar-link
      font-size 0.8rem
      color $text-muted
      padding-left 1rem

      &:hover
        color $text-secondary

      &.active
        color $primary-light
        border-left-color $primary-light

        &::before
          background $primary-light

  .toc-sidebar-sub-header
    margin 0.125rem 0

// 目录容器
.toc-container-sidebar
  .pos-box
    padding 1.25rem
    background rgba(255, 255, 255, 0.95)
    backdrop-filter blur(10px)
    border 1px solid $border-color
    border-radius 12px
    box-shadow 0 4px 20px rgba(0, 0, 0, 0.08)
    transition all 0.3s ease

    & > div:first-child
      padding-bottom 0.75rem
      margin-bottom 0.75rem
      border-bottom 1px solid $border-color
      font-size 0.9rem
      font-weight 600
      color $text-primary
      text-transform uppercase
      letter-spacing 0.05em

    hr
      margin 0.75rem 0
      border none
      height 1px
      background $border-color

    .scroll-box
      & > div
        font-size 0.85rem
        font-weight 600
        color $text-primary
        margin-bottom 0.5rem
        text-overflow ellipsis
        overflow hidden
        white-space nowrap

      .toc-box
        max-height 70vh
        overflow-y auto
        overflow-x hidden
        padding-right 0.5rem

        // 自定义滚动条
        &::-webkit-scrollbar
          width 4px

        &::-webkit-scrollbar-track
          background transparent

        &::-webkit-scrollbar-thumb
          background $border-color
          border-radius 2px

          &:hover
            background $border-color-hover

        ol
          list-style none
          padding 0
          margin 0

          li
            margin 0
            padding 0.25rem 0
            font-size 0.8rem

            a
              color $text-secondary
              text-decoration none
              display block
              padding 0.25rem 0.5rem
              border-radius 4px
              transition all 0.2s ease

              &:hover
                color $primary-color
                background rgba(59, 130, 246, 0.05)

              &.active
                color $primary-color
                background rgba(59, 130, 246, 0.1)
                font-weight 500

          .sub-box
            margin 0

// 深色模式
@media (prefers-color-scheme: dark)
  a.toc-sidebar-link
    color #94a3b8

    &:hover
      color #f1f5f9
      background rgba(96, 165, 250, 0.08)
      border-left-color rgba(96, 165, 250, 0.4)

    &.active
      color #60a5fa
      background rgba(96, 165, 250, 0.15)
      border-left-color #60a5fa

      &::before
        background #60a5fa

    .toc-sidebar-sub-headers a.toc-sidebar-link
      color #64748b

      &:hover
        color #94a3b8

      &.active
        color #93c5fd

        &::before
          background #93c5fd

  .toc-container-sidebar
    .pos-box
      background rgba(15, 23, 42, 0.95)
      border-color #334155
      box-shadow 0 4px 20px rgba(0, 0, 0, 0.3)

      & > div:first-child
        color #f1f5f9

      hr
        background #334155

      .scroll-box
        & > div
          color #f1f5f9

        .toc-box
          ol li a
            color #94a3b8

            &:hover
              color #60a5fa
              background rgba(96, 165, 250, 0.1)

            &.active
              color #60a5fa
              background rgba(96, 165, 250, 0.15)

// 响应式
@media (max-width: 1435px)
  .toc-container-sidebar
    display none !important
