// 导航组件样式优化
// 顶部导航栏链接、下拉菜单等

// 导航链接
.nav-links
  a
    display inline-flex
    align-items center
    color $text-secondary
    font-weight 500
    font-size 0.9rem
    padding 0.25rem 0.5rem
    border-radius 6px
    transition all 0.2s ease
    text-decoration none

    &:hover
      color $primary-color
      background rgba(59, 130, 246, 0.05)

    &.router-link-active
      color $primary-color
      font-weight 600

  .nav-item
    position relative
    margin-left 1rem
    line-height 2rem

    &:first-child
      margin-left 0

    &:hover
      .nav-dropdown
        opacity 1
        visibility visible
        transform translateY(0)

  // 仓库链接
  .repo-link
    margin-left 1.5rem
    display inline-flex
    align-items center
    padding 0.5rem 1rem
    background $bg-secondary
    border 1px solid $border-color
    border-radius 8px
    transition all 0.2s ease

    &:hover
      background $bg-primary
      border-color $primary-color
      color $primary-color
      box-shadow 0 2px 8px rgba(59, 130, 246, 0.15)

    .outbound
      margin-left 0.25rem
      opacity 0.7

// 下拉菜单
.nav-dropdown
  position absolute
  top 100%
  left 0
  min-width 200px
  padding 0.5rem
  margin-top 0.5rem
  background $bg-primary
  border 1px solid $border-color
  border-radius 12px
  box-shadow 0 8px 24px rgba(0, 0, 0, 0.12)
  opacity 0
  visibility hidden
  transform translateY(-10px)
  transition all 0.2s ease
  z-index 100

  a.dropdown-item
    display block
    padding 0.5rem 0.75rem
    color $text-secondary
    border-radius 6px
    margin 0.25rem 0
    font-size 0.875rem

    &:hover
      background rgba(59, 130, 246, 0.08)
      color $primary-color

    &.router-link-active
      background rgba(59, 130, 246, 0.1)
      color $primary-color
      font-weight 600

// 下拉链接组件
.dropdown-link
  position relative
  cursor pointer

  .dropdown-title
    display inline-flex
    align-items center
    gap 0.25rem
    padding 0.25rem 0.5rem

  .arrow
    width 0.5rem
    height 0.5rem
    border-right 2px solid $text-muted
    border-bottom 2px solid $text-muted
    transform rotate(45deg)
    transition transform 0.2s ease

  &:hover
    .arrow
      border-color $primary-color

    .nav-dropdown
      opacity 1
      visibility visible
      transform translateY(0)

// 深色模式
@media (prefers-color-scheme: dark)
  .nav-links
    a
      color #94a3b8

      &:hover
        color #60a5fa
        background rgba(96, 165, 250, 0.1)

      &.router-link-active
        color #60a5fa

    .repo-link
      background rgba(148, 163, 184, 0.1)
      border-color #334155

      &:hover
        background rgba(148, 163, 184, 0.05)
        border-color #60a5fa
        color #60a5fa
        box-shadow 0 2px 8px rgba(96, 165, 250, 0.2)

  .nav-dropdown
    background #1e293b
    border-color #334155
    box-shadow 0 8px 24px rgba(0, 0, 0, 0.3)

    a.dropdown-item
      color #94a3b8

      &:hover
        background rgba(96, 165, 250, 0.15)
        color #60a5fa

      &.router-link-active
        background rgba(96, 165, 250, 0.2)

  .dropdown-link
    .arrow
      border-color #64748b

    &:hover .arrow
      border-color #60a5fa

// 移动端导航
@media (max-width: $MQMobile)
  .nav-links
    .nav-item
      margin-left 0
      width 100%

      a
        display block
        padding 0.75rem 1rem
        border-radius 0

    .repo-link
      margin-left 0
      margin-top 0.5rem
      border none
      background transparent

      &:hover
        background rgba(96, 165, 250, 0.1)

  .nav-dropdown
    position static
    opacity 1
    visibility visible
    transform none
    margin-top 0
    padding-left 1.5rem
    border none
    background transparent
    box-shadow none

    a.dropdown-item
      padding 0.5rem 0

// 搜索框美化
.search-box
  margin-right 0.5rem

  input
    width 10rem
    padding 0.4rem 0.75rem 0.4rem 2rem
    font-size 0.875rem
    border 1px solid $border-color
    border-radius 8px
    background $bg-secondary
    color $text-primary
    transition all 0.2s ease

    &:focus
      width 15rem
      background $bg-primary
      border-color $primary-color
      outline none
      box-shadow 0 0 0 3px rgba(59, 130, 246, 0.1)

    &::placeholder
      color $text-muted

  .suggestions
    position absolute
    top 100%
    left 0
    right 0
    margin-top 0.5rem
    padding 0.5rem
    background $bg-primary
    border 1px solid $border-color
    border-radius 12px
    box-shadow 0 8px 24px rgba(0, 0, 0, 0.12)
    max-height 400px
    overflow-y auto
    z-index 100

    .suggestion
      padding 0.5rem 0.75rem
      border-radius 6px
      cursor pointer
      transition background 0.2s ease

      &:hover
        background rgba(59, 130, 246, 0.08)

      &.focused
        background rgba(59, 130, 246, 0.1)

      .page-title
        font-weight 600
        color $text-primary

      .header
        color $text-muted
        font-size 0.875rem

@media (prefers-color-scheme: dark)
  .search-box input
    background rgba(148, 163, 184, 0.1)
    border-color #334155
    color #f1f5f9

    &:focus
      background rgba(148, 163, 184, 0.05)
      border-color #60a5fa
      box-shadow 0 0 0 3px rgba(96, 165, 250, 0.15)

    &::placeholder
      color #64748b

  .search-box .suggestions
    background #1e293b
    border-color #334155
    box-shadow 0 8px 24px rgba(0, 0, 0, 0.3)

    .suggestion
      &:hover
        background rgba(96, 165, 250, 0.15)

      &.focused
        background rgba(96, 165, 250, 0.2)

      .page-title
        color #f1f5f9

      .header
        color #64748b
